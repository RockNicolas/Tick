generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  demands   DayDemand[]
  goals     Goal[]
}

model Item {
  id          String   @id @default(cuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

/// Demandas do calendário mensal (uma linha por item; `dateKey` = YYYY-MM-DD).
model DayDemand {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateKey   String
  title     String
  category  String   @default("geral")
  note      String   @default("")
  color     String   @default("#f59e0b")
  priority  String   @default("media")
  /// Horário local "HH:mm" para exibição na grade semanal (opcional).
  startTime String?
  endTime   String?
  done      Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dateKey])
  @@index([userId, dateKey])
  @@index([userId, category, done])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String   @default("geral")
  targetCount Int    @default(1)
  progress  Int      @default(0)
  status    String   @default("active")
  dueDate   DateTime?
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, completedAt])
}
